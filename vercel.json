{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "builds": [
    { "src": "api/extract_pdf.py", "use": "@vercel/python" },
    { "src": "api/state.py", "use": "@vercel/python" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.webmanifest", "use": "@vercel/static" },
    { "src": "icons/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/extract_pdf", "dest": "api/extract_pdf.py" },
    { "src": "/api/state", "dest": "api/state.py" },
    { "handle": "filesystem" }
  ]
}
